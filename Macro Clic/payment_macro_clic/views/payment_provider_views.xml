<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="payment_provider_form_macro_clic" model="ir.ui.view">
        <field name="name">payment.provider.form.macro_clic</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <group name="provider_credentials" position="inside">
                <group invisible="code != 'macro_clic'">
                    <field name="macro_clic_commerce_id"/>
                    <field name="macro_clic_secret_key" password="True"/>
                    <field name="macro_clic_phrase" password="True"/>
                    <field name="macro_clic_branch_id"/>
                    <field name="macro_clic_ente_code"/>
                </group>
            </group>
        </field>
    </record>
</odoo>