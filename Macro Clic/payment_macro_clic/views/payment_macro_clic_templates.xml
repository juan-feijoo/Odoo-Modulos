<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="redirect_form">
        <form t-att-action="api_url" method="post" id="o_payment_redirect_form" class="d-none" target="_top">
            <t t-foreach="url_params" t-as="param">
                <input type="hidden" t-att-name="param" t-att-value="url_params[param]" />
            </t>
            <button type="submit" class="btn btn-primary">
                Redirigiendo a Macro Clic...
            </button>
        </form>
    </template>
</odoo>