<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="payment_provider_macro_clic" model="payment.provider">
        <field name="name">Macro Clic</field>
        <field name="code">macro_clic</field>
        <field name="is_published">True</field>
        <field name="image_128" type="base64" file="payment_macro_clic/static/description/icon.svg"/>
        <!-- Vinculamos el método de pago automáticamente -->
        <field name="payment_method_ids" eval="[(4, ref('payment_macro_clic.payment_method_macro_clic'))]"/>
        <!-- Vinculamos la vista de redirección -->
        <field name="redirect_form_view_id" ref="payment_macro_clic.redirect_form"/>
    </record>
</odoo>