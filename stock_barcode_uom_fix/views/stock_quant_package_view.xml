<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_quant_package_form_inherit_uom_fix" model="ir.ui.view">
        <field name="name">stock.quant.package.form.inherit.uom.fix</field>
        <field name="model">stock.quant.package</field>
        <field name="inherit_id" ref="stock.view_quant_package_form"/>
        <field name="arch" type="xml">
            
            <xpath expr="//field[@name='quant_ids']//field[@name='quantity']" position="attributes">
                <attribute name="column_invisible">True</attribute>
            </xpath>
            <xpath expr="//field[@name='quant_ids']//field[@name='product_uom_id']" position="attributes">
                <attribute name="column_invisible">True</attribute>
            </xpath>

            <!-- Agregamos nuestros campos calculados (Bultos) -->
            <xpath expr="//field[@name='quant_ids']//field[@name='lot_id']" position="after">
                <field name="pack_custom_qty" string="Cantidad"/>
                <field name="pack_custom_uom_id" string="Unidad de medida"/>
            </xpath>

        </field>
    </record>
</odoo>