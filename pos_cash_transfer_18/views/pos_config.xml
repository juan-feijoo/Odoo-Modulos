<odoo>
    <record id="view_pos_config_form_inherit_transfer" model="ir.ui.view">
        <field name="name">pos.config.form.transfer</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='other_devices']/ancestor::setting" position="after">
                <setting id="pos_keep_amount_setting" string="Monto a conservar" help="Se conservará este monto al cerrar sesión para el fondo de caja del día siguiente.">
                    <field name="pos_keep_amount"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>