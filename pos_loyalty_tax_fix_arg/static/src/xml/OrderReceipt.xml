<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <!-- Heredamos el ticket del POS -->
    <t t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">
        <xpath expr="//t[@t-foreach='props.data.tax_details']//*[contains(@t-esc, 'tax.name') or contains(@t-esc, 'tax.tax.name')]" position="replace">
            <t t-set="tax_display_name" t-value="tax.name || (tax.tax &amp;&amp; tax.tax.name) || ''"/>
            
            <!-- CORRECCIÓN: Usamos un array con .some() para atrapar cualquier variante -->
            <t t-if="['impuesto interno', 'imp interno', 'imp int'].some(pattern => tax_display_name.toLowerCase().includes(pattern))">
                <span>Impuesto interno</span>
            </t>
            <t t-else="">
                <span t-esc="tax_display_name"/>
            </t>
        </xpath>
    </t>
</templates>